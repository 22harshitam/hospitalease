#!/usr/bin/env python3
"""
Simple test server to demonstrate API integration
"""
from flask import Flask, jsonify, request
from flask_cors import CORS
import jwt
from datetime import datetime, timedelta
import hashlib

app = Flask(__name__)
CORS(app)

# Configuration
SECRET_KEY = "your-super-secret-key-change-in-production"
ALGORITHM = "HS256"

# Sample data
doctors = [
    {
        "id": "1",
        "name": "Dr. Arun Ravi",
        "specialization": "Cardiologist",
        "rating": 4.8,
        "reviews": 120,
        "experience": "12+ Years Experience",
        "image_url": "https://img.freepik.com/free-photo/doctor-with-his-arms-crossed-white-background_1368-5790.jpg",
        "is_available": True,
        "biography": "Dr. Arun Ravi is a senior Cardiologist in Mumbai with over 12 years of experience at AIIMS Delhi.",
        "consultation_fee": 1200,
        "email": "doctor@hospital.com"
    },
    {
        "id": "2",
        "name": "Dr. Priya Sharma",
        "specialization": "Pediatrician",
        "rating": 4.6,
        "reviews": 98,
        "experience": "8+ Years Experience",
        "image_url": "https://img.freepik.com/free-photo/pleased-young-female-doctor-white-coat-with-stethoscope-around-neck-standing-with-folded-arms-isolated-white-wall_231208-2200.jpg",
        "is_available": True,
        "biography": "Dr. Priya Sharma is a leading Pediatrician in Bangalore, known for her gentle care for infants and children.",
        "consultation_fee": 800,
        "email": "priya@hospital.com"
    }
]

patients = []  # Patients register themselves, no hardcoded data

appointments = [
    {
        "id": "1",
        "doctor_id": "1",
        "date": "2024-01-15T10:00:00",
        "time_slot": "10:00 AM",
        "patient_name": "Arjun Mehta",
        "patient_age": "42",
        "patient_phone": "9876543210",
        "patient_email": None,
        "patient_symptoms": "Mild chest pain and high blood pressure",
        "status": "Upcoming",
        "token": "HEA12345",
        "created_at": "2024-01-14T12:00:00"
    }
]

# Helper functions
def create_access_token(data: dict, expires_delta: timedelta = None):
    to_encode = data.copy()
    if expires_delta:
        expire = datetime.utcnow() + expires_delta
    else:
        expire = datetime.utcnow() + timedelta(minutes=30)
    to_encode.update({"exp": expire})
    encoded_jwt = jwt.encode(to_encode, SECRET_KEY, algorithm=ALGORITHM)
    return encoded_jwt

def verify_token(token: str):
    try:
        payload = jwt.decode(token, SECRET_KEY, algorithms=[ALGORITHM])
        return payload
    except jwt.PyJWTError:
        return None

# Routes
@app.route("/")
def root():
    return jsonify({"message": "HospitalEasy API is running"})

@app.route("/health")
def health():
    return jsonify({"status": "healthy"})

@app.route("/api/auth/test")
def auth_test():
    return jsonify({"message": "Authentication endpoint is working"})

@app.route("/api/auth/login-json", methods=["POST"])
def login():
    data = request.get_json()
    email = data.get("email")
    password = data.get("password")
    user_type = data.get("user_type", "doctor")  # Default to doctor
    
    # Doctor authentication
    if user_type == "doctor":
        if email == "doctor@hospital.com" and password == "password123":
            access_token = create_access_token(data={"sub": email, "user_type": "doctor"})
            return jsonify({
                "access_token": access_token,
                "token_type": "bearer",
                "user_type": "doctor"
            })
        else:
            return jsonify({"detail": "Invalid doctor credentials"}), 401
    
    # Patient authentication
    elif user_type == "patient":
        if email == "patient@hospital.com" and password == "password123":
            access_token = create_access_token(data={"sub": email, "user_type": "patient"})
            return jsonify({
                "access_token": access_token,
                "token_type": "bearer",
                "user_type": "patient"
            })
        else:
            return jsonify({"detail": "Invalid patient credentials"}), 401
    
    else:
        return jsonify({"detail": "Invalid user type"}), 400

@app.route("/api/auth/patient/register", methods=["POST"])
def register_patient():
    data = request.get_json()
    name = data.get("name")
    email = data.get("email")
    password = data.get("password")
    phone = data.get("phone")
    age = data.get("age")
    
    # Simple validation
    if not all([name, email, password, phone, age]):
        return jsonify({"detail": "Missing required fields"}), 400
    
    # Check if patient already exists
    existing_patient = next((p for p in patients if p["email"] == email), None)
    if existing_patient:
        return jsonify({"detail": "Patient with this email already exists"}), 400
    
    # Create new patient
    new_patient = {
        "id": str(len(patients) + 1),
        "name": name,
        "email": email,
        "phone": phone,
        "age": age,
        "blood_group": "O+",  # Default
        "address": data.get("address", ""),
        "emergency_contact": data.get("emergency_contact", ""),
        "created_at": datetime.utcnow().isoformat()
    }
    
    patients.append(new_patient)
    
    # Create access token
    access_token = create_access_token(data={"sub": email, "user_type": "patient"})
    
    return jsonify({
        "access_token": access_token,
        "token_type": "bearer",
        "user_type": "patient",
        "patient": new_patient
    }), 201

@app.route("/api/auth/patient/login", methods=["POST"])
def patient_login():
    data = request.get_json()
    email = data.get("email")
    password = data.get("password")
    
    # Find patient by email
    patient = next((p for p in patients if p["email"] == email), None)
    
    if not patient:
        return jsonify({"detail": "Patient not found. Please register first."}), 404
    
    # Simple password check (in production, use hashed passwords)
    if password == "password123":  # All registered patients use same password for demo
        access_token = create_access_token(data={"sub": email, "user_type": "patient"})
        return jsonify({
            "access_token": access_token,
            "token_type": "bearer",
            "user_type": "patient",
            "patient": patient
        })
    else:
        return jsonify({"detail": "Invalid password"}), 401

@app.route("/api/auth/me")
def get_current_user():
    auth_header = request.headers.get("Authorization")
    if not auth_header or not auth_header.startswith("Bearer "):
        return jsonify({"detail": "Not authenticated"}), 401
    
    token = auth_header.split(" ")[1]
    payload = verify_token(token)
    
    if not payload:
        return jsonify({"detail": "Invalid token"}), 401
    
    user_type = payload.get("user_type", "doctor")
    email = payload.get("sub")
    
    # Return doctor info
    if user_type == "doctor":
        doctor = next((d for d in doctors if d["email"] == email), None)
        if doctor:
            return jsonify({
                "user_type": "doctor",
                **doctor
            })
        else:
            return jsonify({"detail": "Doctor not found"}), 404
    
    # Return patient info
    elif user_type == "patient":
        patient = next((p for p in patients if p["email"] == email), None)
        if patient:
            return jsonify({
                "user_type": "patient",
                **patient
            })
        else:
            return jsonify({"detail": "Patient not found"}), 404
    
    else:
        return jsonify({"detail": "Invalid user type"}), 400

@app.route("/api/doctors/")
def get_doctors():
    return jsonify(doctors)

@app.route("/api/doctors/<doctor_id>")
def get_doctor(doctor_id):
    doctor = next((d for d in doctors if d["id"] == doctor_id), None)
    if doctor:
        return jsonify(doctor)
    else:
        return jsonify({"detail": "Doctor not found"}), 404

@app.route("/api/appointments/")
def get_appointments():
    auth_header = request.headers.get("Authorization")
    if auth_header and auth_header.startswith("Bearer "):
        token = auth_header.split(" ")[1]
        payload = verify_token(token)
        if payload:
            # Filter appointments for current doctor
            user_appointments = [apt for apt in appointments if apt["doctor_id"] == "1"]
            return jsonify(user_appointments)
    
    return jsonify(appointments)

@app.route("/api/appointments/", methods=["POST"])
def create_appointment():
    data = request.get_json()
    new_appointment = {
        "id": str(len(appointments) + 1),
        "doctor_id": data["doctor_id"],
        "date": data["date"],
        "time_slot": data["time_slot"],
        "patient_name": data["patient_details"]["name"],
        "patient_age": data["patient_details"]["age"],
        "patient_phone": data["patient_details"]["phone"],
        "patient_email": data["patient_details"].get("email"),
        "patient_symptoms": data["patient_details"].get("symptoms"),
        "status": "Upcoming",
        "token": f"HEA{len(appointments) + 1:05d}",
        "created_at": datetime.utcnow().isoformat()
    }
    appointments.append(new_appointment)
    return jsonify(new_appointment), 201

